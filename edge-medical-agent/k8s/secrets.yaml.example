# Copy this file to secrets.yaml and fill in actual values
# DO NOT commit secrets.yaml to version control!
apiVersion: v1
kind: Secret
metadata:
  name: triage-secrets
  namespace: medgemma-triage
type: Opaque
stringData:
  # AWS API key (if required)
  AWS_API_KEY: "your-aws-api-key"
  # SMTP credentials for email notifications
  SMTP_USER: "your-smtp-username"
  SMTP_PASSWORD: "your-smtp-password"
  FROM_EMAIL: "alerts@yourdomain.com"
  # Clinical notification recipient
  CLINICAL_NOTIFICATION_EMAIL: "clinical-team@yourdomain.com"
