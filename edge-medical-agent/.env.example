# Tenant
TENANT_ID=practice-001

# AWS API
AWS_API_URL=https://<your-api-id>.execute-api.<region>.amazonaws.com/prod
AWS_API_KEY=

# Scheduler
POLL_INTERVAL_SECONDS=60
MAX_ITEMS_PER_POLL=50
QUEUE_BACKPRESSURE_THRESHOLD=20

# Model endpoints (DGX Spark)
MEDGEMMA_27B_URL=http://localhost:8357
MEDGEMMA_4B_URL=http://localhost:8358

# Infrastructure (local on DGX Spark)
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=medgemma_triage
OPENSEARCH_URL=http://localhost:9200

# Notification thresholds
THRESHOLD_ROUTINE=29
THRESHOLD_FOLLOWUP=30
THRESHOLD_IMPORTANT=50
THRESHOLD_URGENT=75

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourdomain.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=alerts@yourdomain.com
CLINICAL_NOTIFICATION_EMAIL=doctor@practice.com
TECH_SUPPORT_EMAIL=support@yourdomain.com

# Vector analysis
RAPID_CHANGE_THRESHOLD_PERCENT=20.0
RAPID_CHANGE_WINDOW_DAYS=30
MAX_HISTORICAL_VALUES=5

# LOINC Configuration
LOINC_DATA_DIR=./data/loinc
LOINC_SYNONYMS_FILE=./data/loinc/synonyms.json
LOINC_ENABLE_FUZZY=false
LOINC_FUZZY_THRESHOLD=80
LOINC_CACHE_SIZE=1000
LOINC_CACHE_TTL_SECONDS=3600

# Tapestry (patient body-map visualization)
TAPESTRY_ENABLED=false
